// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Flatpack > Flatpack diff 'string', 'string' 1`] = `
"Index: data
===================================================================
--- data
+++ data
"
`;

exports[`Flatpack > Flatpack diff undefined, undefined 1`] = `
"Index: data
===================================================================
--- data
+++ data
"
`;
